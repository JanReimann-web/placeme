rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function incomingJobStartsPending() {
      return request.resource.data.status == "pending" &&
        request.resource.data.errorMessage == null;
    }

    match /users/{userId} {
      allow create, read, update: if ownsUser(userId);
      allow delete: if false;
    }

    match /profiles/{profileId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /profilePhotos/{photoId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /generationJobs/{jobId} {
      allow create: if ownsIncomingDocument() && incomingJobStartsPending();
      allow read, delete: if ownsExistingDocument();
      allow update: if false;
    }

    match /generatedImages/{imageId} {
      allow read: if ownsExistingDocument();
      allow create, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow create: if false;
      allow read: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
      allow delete: if ownsExistingDocument();
    }

    match /notificationDevices/{deviceId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }
  }
}
