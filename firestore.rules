rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow create, read, update: if ownsUser(userId);
      allow delete: if false;
    }

    match /profiles/{profileId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /profilePhotos/{photoId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /generationJobs/{jobId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /generatedImages/{imageId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }
  }
}
